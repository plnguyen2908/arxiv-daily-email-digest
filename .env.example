# Core app settings
APP_ENV=dev
DB_PATH=data/arxiv_digest.db
TOPICS_CONFIG_PATH=config/topics.yaml
DATA_DIR=data
TEXT_CACHE_DIR=data/text_cache
TOP_K_PER_KEYWORD=0
LOOKBACK_HOURS=24
MAX_RESULTS_PER_TOPIC=1200
REQUEST_TIMEOUT_SECONDS=20
ARXIV_USER_AGENT=arxiv-digest-bot/0.1 (+https://github.com/yourname/arxiv-daily-email-digest)
OUTPUT_RETENTION_DAYS=30
TEXT_CACHE_RETENTION_DAYS=45
MAX_OUTPUT_FILES=120
MAX_TEXT_CACHE_FILES=2000
DB_MAX_RUNS=1000
DB_MAX_KEYWORD_SCORES=50000
DB_MAX_SENT_LOG_ROWS=100000
DRY_RUN_USE_LAST_SUCCESS=0
DRY_RUN_IGNORE_SENT_LOG=1
RUN_IGNORE_SENT_LOG=0
RUN_USE_LAST_SUCCESS=1
RUN_FALLBACK_TO_LOOKBACK_IF_EMPTY=1
RUN_CURRENT_DATE_ONLY=1
RUN_TIMEZONE=America/Chicago
UI_DATA_DIR=data/ui_store
UI_MAX_DATA_MB=500
UI_FETCH_FALLBACK_DAYS=1
UI_DISK_MAX_USED_PERCENT=90
UI_DISK_MIN_FREE_MB=2048
KEYWORD_ADMIN_PASSWORD=Thienphuc2004
CORS_ORIGINS=*

# Email delivery (Gmail recommended for this setup)
EMAIL_TO=you@gmail.com
EMAIL_FROM=you@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_TIMEOUT_SECONDS=60
SMTP_RETRIES=2
SMTP_STARTTLS=0
SMTP_USE_SSL=1
SMTP_FALLBACK_SSL=1
